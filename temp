#!/bin/bash
# Do NOT use set -e. We want to aggregate all reports even if one scanner finds issues/fails.

# Configuration & Paths
SOURCE_DIR="/src"
OUTPUT_DIR="${SOURCE_DIR}/pqc-reports"
THEIA_OUT="${OUTPUT_DIR}/theia-crypto.json"
CDXGEN_OUT="${OUTPUT_DIR}/cdxgen-dependencies.json"
FINAL_CBOM="${SOURCE_DIR}/final-cbom.json"

# Minimal valid CycloneDX v1.5 skeleton for graceful degradation
VALID_EMPTY_CBOM='{"bomFormat": "CycloneDX","specVersion": "1.5","serialNumber": "urn:uuid:00000000-0000-0000-0000-000000000000","version": 1,"components": []}'

mkdir -p "$OUTPUT_DIR"

echo "================================================="
echo " Starting Full DevSecOps Pipeline Analysis       "
echo "================================================="

# -------------------------------------------------
# 1. SECRET SCANNING (Gitleaks)
# -------------------------------------------------
echo "[1/5] Running Secret Detection (Gitleaks)..."
# Exit code 0 ensures the script continues even if secrets are found.
# Outputs in standard JSON for custom reporting or SARIF for GitLab integration.
gitleaks detect --source "$SOURCE_DIR" \
    --report-format json \
    --report-path "$OUTPUT_DIR/gl-secret-detection-report.json" \
    --exit-code 0

# -------------------------------------------------
# 2. SAST SCANNING (Semgrep)
# -------------------------------------------------
echo "[2/5] Running SAST (Semgrep)..."
# Uses Semgrep's native GitLab SAST format which GitLab CI ingests seamlessly.
semgrep scan --config auto \
    --gitlab-sast > "$OUTPUT_DIR/gl-sast-report.json" || true

# -------------------------------------------------
# 3. CRYPTOGRAPHIC PRIMITIVE SCAN (Theia)
# -------------------------------------------------
echo "[3/5] Running PQCA Theia (Crypto Primitives)..."
pqc-theia dir "$SOURCE_DIR" --ignore "node_modules/**" > "$THEIA_OUT" 2>/dev/null

# CRITICAL FIX: If Theia fails or outputs nothing, inject a VALID CycloneDX schema.
# Injecting `{}` causes the cyclonedx-cli merge tool to crash.
if [ ! -f "$THEIA_OUT" ] || [ ! -s "$THEIA_OUT" ]; then
    echo "  -> Warning: Theia scan produced no output. Using empty valid CBOM skeleton."
    echo "$VALID_EMPTY_CBOM" > "$THEIA_OUT"
fi

# -------------------------------------------------
# 4. DEPENDENCY & CBOM SCAN (cdxgen)
# -------------------------------------------------
echo "[4/5] Running cdxgen (Dependencies & Evidence)..."
cdxgen "$SOURCE_DIR" \
    --output "$CDXGEN_OUT" \
    --no-babel \
    --include-crypto \
    --deep \
    --evidence \
    --spec-version 1.5 > /dev/null 2>&1

if [ ! -f "$CDXGEN_OUT" ] || [ ! -s "$CDXGEN_OUT" ]; then
    echo "  -> Warning: cdxgen scan produced no output. Using empty valid CBOM skeleton."
    echo "$VALID_EMPTY_CBOM" > "$CDXGEN_OUT"
fi

# -------------------------------------------------
# 5. MERGE & VULNERABILITY SCAN (CycloneDX & Grype)
# -------------------------------------------------
echo "[5/5] Merging CBOMs and Scanning for Vulnerabilities..."
cyclonedx-cli merge \
    --input-files "$THEIA_OUT" "$CDXGEN_OUT" \
    --output-file "$FINAL_CBOM" \
    --output-format json

if [ -f "$FINAL_CBOM" ]; then
    echo "  -> Unified CBOM successfully generated at $FINAL_CBOM"
    theia_count=$(jq '.components | length' "$FINAL_CBOM" 2>/dev/null || echo 0)
    echo "  -> Total components mapped: $theia_count"

    # Run Grype on the unified CBOM
    # Grype outputs standard JSON which contains vulnerability matching data
    grype "sbom:$FINAL_CBOM" -o json > "$OUTPUT_DIR/grype-vulnerabilities.json" 2>/dev/null
else
    echo "  -> ERROR: Failed to merge CBOM files."
fi

# Permissions fix to ensure GitLab CI runner can capture artifacts
chmod -R 777 "$OUTPUT_DIR" "$FINAL_CBOM"

echo "================================================="
echo " Pipeline Analysis Complete. Reports generated in $OUTPUT_DIR"
echo "================================================="